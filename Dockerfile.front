FROM node:20-alpine AS base
WORKDIR /app

# Installer pnpm pour accélérer les installs (optionnel) sinon npm
RUN corepack enable

# Copier les manifestes
COPY package.json package-lock.json ./

# Installer deps
RUN npm ci

# Copier le reste du code
COPY . .

# Exposer le port Vite
EXPOSE 5173

# Variables par défaut (peuvent être surchargées via compose)
ENV VITE_OLLAMA_URL=http://localhost:11434
ENV VITE_SITEGEN_URL=http://localhost:4000

# Lancer Vite en dev
CMD ["npm", "run", "dev", "--", "--host", "--port", "5173", "--clearScreen", "false"]


