# ============================================================================
# BOOKWISE - Variables d'environnement
# ============================================================================
# Copier ce fichier en .env et remplir les valeurs

# ----------------------------------------------------------------------------
# SUPABASE (obligatoire)
# Obtenir sur : https://supabase.com/dashboard/project/_/settings/api
# ----------------------------------------------------------------------------
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-public-key

# ----------------------------------------------------------------------------
# OPENAI (obligatoire pour la génération IA)
# Obtenir sur : https://platform.openai.com/api-keys
# ----------------------------------------------------------------------------
VITE_OPENAI_API_KEY=sk-proj-...
VITE_OPENAI_MODEL=gpt-4o-mini

# ----------------------------------------------------------------------------
# BACKEND (optionnel — génération ZIP + déploiement)
# ----------------------------------------------------------------------------
VITE_SITEGEN_URL=http://localhost:4000
VITE_ORCHESTRATOR_URL=http://localhost:4001
